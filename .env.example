SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433
SQLSERVER_DB=DataWareHouse_RC
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=your_password_here
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# Usuario opcional, readonly, para o assistente de IA.
# Crie com sql/005_ia_security_setup.sql antes de habilitar.
SQLSERVER_IA_USER=
SQLSERVER_IA_PASSWORD=

# IA generativa opcional. O projeto deve rodar sem chave externa.
LLM_PROVIDER=groq
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

NEXT_PUBLIC_API_URL=http://localhost:8000
