# SQL Server - conexão principal
SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433
SQLSERVER_DB=DataWareHouse_RC
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=your_password_here
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server

# SQL Server - usuário restrito do assistente (opcional)
SQLSERVER_IA_USER=
SQLSERVER_IA_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Provedor de LLM (none, gemini ou openai)
LLM_PROVIDER=none
LLM_MODEL=

# Chaves de provedores (opcionais)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Reservado para uma futura integração com Groq
GROQ_API_KEY=
